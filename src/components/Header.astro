---
import { siteConfig } from "../config/site";
import MobileMenu from "./MobileMenu.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/#uslugi", label: "Usługi" },
  { href: "/#dlaczego-my", label: "Dlaczego my" },
  { href: "/kontakt", label: "Kontakt" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 glassmorphism border-b border-[var(--border-color)]"
>
  <div class="container-custom">
    <div class="flex items-center justify-between h-[96px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/images/logo-haris_logo.webp"
          alt="Haris-Instal Logo"
          class="h-16 w-auto transition-transform duration-300 group-hover:scale-105"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="relative px-4 py-2 rounded-lg font-medium transition-all duration-200 text-[var(--text-primary)] hover:text-white hover:[background:linear-gradient(135deg,#173d8d_0%,#2d6de0_100%)] hover:shadow-md"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Right side: Theme toggle + CTA + Hamburger -->
      <div class="flex items-center gap-2">
        <ThemeToggle />

        <!-- Phone CTA (desktop only) -->
        <a
          href={siteConfig.contact.phone.href}
          class="hidden lg:flex btn-primary text-sm"
        >
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          Zadzwoń
        </a>

        <!-- Hamburger button (mobile only) -->
        <button
          id="hamburger-button"
          type="button"
          class="md:hidden p-2 rounded-lg transition-all duration-200 text-black hover:text-white hover:bg-black"
          aria-label="Otwórz menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <!-- Hamburger icon (shown when closed) -->
          <svg class="w-6 h-6 block [[aria-expanded=true]_&]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- X icon (shown when open) -->
          <svg class="w-6 h-6 hidden [[aria-expanded=true]_&]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<MobileMenu currentPath={currentPath} />

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-[96px]"></div>
